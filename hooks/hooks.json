{
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/setup.js\"",
            "timeout": 600000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_claude-mem_mcp-search__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/dist/hooks/post-tool-use.js",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
